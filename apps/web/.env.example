# ─── Feature Flags ────────────────────────────────────────────────────────────
# Управление доступностью модулей.
# false → 403 на API, страница показывает "Раздел временно недоступен".
# Runtime переопределения через Admin Panel (/admin) имеют приоритет над ENV.

# Portal modules
PUBLIC_FEATURE_EXCHANGE=true
PUBLIC_FEATURE_BLOG=true
PUBLIC_FEATURE_CONTENT=true
PUBLIC_FEATURE_WEATHER=true
PUBLIC_FEATURE_CARS=true
PUBLIC_FEATURE_MAPS=true

# Standalone apps (embedded in apps/web as native SvelteKit routes)
PUBLIC_FEATURE_ADMIN=true
PUBLIC_FEATURE_BANK=true
PUBLIC_FEATURE_DEVTOOLS=true
PUBLIC_FEATURE_REPORTS=true
PUBLIC_FEATURE_REMOTION=true

# ─── Render Mode ──────────────────────────────────────────────────────────────
# ssr — данные грузятся сервером, HTML отдаётся пре-рендеренным (SEO, быстрый FCP)
# spa — сервер отдаёт пустую оболочку, данные грузит клиент через internal API proxy
# Standalone apps are always ssr — the render mode flag has no effect for them.

# Portal modules
PUBLIC_RENDER_MODE_EXCHANGE=ssr
PUBLIC_RENDER_MODE_BLOG=ssr
PUBLIC_RENDER_MODE_CONTENT=ssr
PUBLIC_RENDER_MODE_WEATHER=ssr
PUBLIC_RENDER_MODE_CARS=ssr
PUBLIC_RENDER_MODE_MAPS=ssr

# Standalone apps (always ssr — value ignored by hooks.server.ts)
PUBLIC_RENDER_MODE_ADMIN=ssr
PUBLIC_RENDER_MODE_BANK=ssr
PUBLIC_RENDER_MODE_DEVTOOLS=ssr
PUBLIC_RENDER_MODE_REPORTS=ssr
PUBLIC_RENDER_MODE_REMOTION=ssr

# ─── Runtime Flags Store ──────────────────────────────────────────────────────
# Путь к файлу runtime-переопределений флагов (записывается через /admin/api/flags,
# читается в hooks.server.ts на каждый запрос).
# По умолчанию: <cwd>/flags-override.json
# В продакшне укажите абсолютный путь:
# FLAGS_STORE_PATH=/var/data/flags-override.json

# ─── Analytics ────────────────────────────────────────────────────────────────
# Оставьте пустым — провайдер будет отключён. Все необязательны.

# Google Analytics 4 Measurement ID (G-XXXXXXXXXX)
PUBLIC_GA4_ID=

# Heap Analytics App ID
PUBLIC_HEAP_APP_ID=

# Amplitude API Key
PUBLIC_AMPLITUDE_API_KEY=
